{
	"name": "convert-case",
	"version": "0.1.2",
	"description": "Small, dependency-free case converter for selected text.",
	"private": true,
	"license": "MIT",
	"packageManager": "npm@11.8.0",
	"engines": {
		"node": ">=22.0.0",
		"npm": ">=11.0.0"
	},
	"scripts": {
		"check": "node --check main.js && node --check scripts/bump-version.mjs && node --test tests/*.test.js",
		"release:bump": "node scripts/bump-version.mjs",
		"release:major": "node scripts/bump-version.mjs major",
		"release:minor": "node scripts/bump-version.mjs minor",
		"release:patch": "node scripts/bump-version.mjs patch",
		"test": "node --test tests/*.test.js"
	},
	"dependencies": {},
	"devDependencies": {}
}
